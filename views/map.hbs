<div class="map-detail">
  <div class="map-header">
    <a href="/game/{{game.id}}" class="back-link">← Back to {{game.name}}</a>
    <h1>{{map.name}}</h1>
    <div class="map-info">
      <span class="game-badge">{{game.name}} ({{game.year}})</span>
      <span class="map-type">{{mapType map}}</span>
    </div>
  </div>

  <div class="map-content">
    <section class="easter-egg-section">
      <h2>Easter Egg Walkthrough</h2>
      <div class="easter-egg-body">
        <p class="placeholder">Easter egg guide for <strong>{{map.name}}</strong> coming soon.</p>
        <p class="placeholder">Add the easter egg steps and details here!</p>
      </div>
    </section>
  </div>
</div>
